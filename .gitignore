# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CineForge uploads and renders
/public/renders/
/public/uploads/*
!/public/uploads/promo.mp4

# Worker build artefacts and debug output
infrastructure/render-gcp/dist/tmp/
infrastructure/render-gcp/dist/assets/
infrastructure/render-gcp/output_no_text.mp4
infrastructure/render-gcp/test_log.txt
test_qsv.mp4
test_qsv_hevc.mp4
