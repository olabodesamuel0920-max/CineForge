{
  "name": "cineforge-render-gcp",
  "version": "1.0.0",
  "description": "CineForge Google Cloud Run video rendering service",
  "main": "dist/server.js",
  "scripts": {
    "build": "node -e \"const fs = require('fs'); fs.copyFileSync('../../src/lib/soundDesignCompiler.ts', './soundDesignCompiler.ts');\" && tsc",
    "start": "node dist/server.js",
    "dev": "node -e \"const fs = require('fs'); fs.copyFileSync('../../src/lib/soundDesignCompiler.ts', './soundDesignCompiler.ts');\" && ts-node server.ts",
    "test:local": "node -e \"const fs = require('fs'); fs.copyFileSync('../../src/lib/soundDesignCompiler.ts', './soundDesignCompiler.ts');\" && ts-node test-local.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.0.0",
    "@google-cloud/storage": "^7.7.0",
    "express": "^4.18.2",
    "jpeg-js": "^0.4.4",
    "picojs": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
